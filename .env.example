# RUTA: .env.example — copiar como .env y llenar los valores
# FOODIFY Backend v3.2 — Variables de entorno

# ── Servidor ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── MySQL ─────────────────────────────────────────────────────────
# IMPORTANTE: Usar 127.0.0.1 en lugar de localhost en Windows
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_USER=foodify
DATABASE_PASSWORD=foodify_pass
DATABASE_NAME=foodify_db
DATABASE_POOL_SIZE=10

# ── Redis (WebSockets + BullMQ) ───────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ── JWT ───────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=foodify_dev_access_secret_change_in_prod
JWT_REFRESH_SECRET=foodify_dev_refresh_secret_change_in_prod
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ── AWS S3 (imágenes de platillos y logos) ────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=us-east-1

# ── Firebase FCM (push notifications Android — Solo Premium) ──────
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ── Email (Nodemailer / SendGrid) ─────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@foodify.mx

# ── Pagos SaaS (solo servidor — nunca al cliente) ─────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CONEKTA_API_KEY=

# ── Rate Limiting ─────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ── CORS ──────────────────────────────────────────────────────────
# Separar múltiples orígenes con comas
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
